#!/usr/bin/env bash
# Check Docs Sidebar
# Verifies that newly added published docs have corresponding entries in docs/sidebars.ts.
# Usage: script/check-docs-sidebar [base-ref] [current-ref]

set -euo pipefail

BASE_REF="${1:-origin/master}"
CURRENT_REF="${2:-HEAD}"
SIDEBAR_FILE="docs/sidebars.ts"
EXCLUSIONS_FILE="docs/.sidebar-exclusions"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

if [ ! -f "$SIDEBAR_FILE" ]; then
  echo -e "${RED}Error: $SIDEBAR_FILE not found${NC}" >&2
  exit 1
fi

if ! git rev-parse --verify "$BASE_REF" >/dev/null 2>&1; then
  git fetch --no-tags --depth=50 origin master:refs/remotes/origin/master >/dev/null 2>&1 || true
fi

if ! git rev-parse --verify "${BASE_REF}^{commit}" >/dev/null 2>&1; then
  echo -e "${RED}Error: cannot resolve base ref: $BASE_REF${NC}" >&2
  exit 1
fi

if ! git rev-parse --verify "${CURRENT_REF}^{commit}" >/dev/null 2>&1; then
  echo -e "${RED}Error: cannot resolve current ref: $CURRENT_REF${NC}" >&2
  exit 1
fi

if ! MERGE_BASE=$(git merge-base "$BASE_REF" "$CURRENT_REF" 2>/dev/null); then
  echo -e "${RED}Error: cannot find merge base between $BASE_REF and $CURRENT_REF${NC}" >&2
  exit 1
fi

if ! ADDED_FILES=$(git diff --name-only --diff-filter=AR "$MERGE_BASE" "$CURRENT_REF"); then
  echo -e "${RED}Error: cannot diff comparison between $BASE_REF and $CURRENT_REF${NC}" >&2
  exit 1
fi

if [ -z "${CI:-}" ] && [ "$CURRENT_REF" = "HEAD" ]; then
  STAGED_NEW=$(git diff --cached --name-only --diff-filter=AR 2>/dev/null || echo "")
  UNTRACKED_NEW=$(git ls-files --others --exclude-standard -- 'docs/*.md' 'docs/**/*.md' 'docs/*.mdx' 'docs/**/*.mdx' 2>/dev/null || echo "")
  ADDED_FILES=$(printf "%s\n%s\n%s" "$ADDED_FILES" "$STAGED_NEW" "$UNTRACKED_NEW" | sort -u | grep -v '^$' || echo "")
fi

DOC_FILES=$(echo "$ADDED_FILES" | grep -E '^docs/.*\.(md|mdx)$' | grep -vE '^docs/(adr|roadmap)/' || echo "")

if [ -z "$DOC_FILES" ]; then
  echo -e "${GREEN}OK No new published doc files detected${NC}"
  exit 0
fi

EXCLUSION_LIST=""
if [ -f "$EXCLUSIONS_FILE" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [ -z "$line" ] && continue
    EXCLUSION_LIST="${EXCLUSION_LIST}${line}"$'\n'
  done < "$EXCLUSIONS_FILE"
fi

SIDEBAR_CONTENT=$(grep -v '^[[:space:]]*//' "$SIDEBAR_FILE" | sed 's|[[:space:]]//.*||')

MISSING=()
CHECKED=0
EXCLUDED=0

while IFS= read -r file; do
  [ -z "$file" ] && continue
  CHECKED=$((CHECKED + 1))

  DOC_ID="${file#docs/}"
  DOC_ID="${DOC_ID%.md}"
  DOC_ID="${DOC_ID%.mdx}"

  if printf '%s' "$EXCLUSION_LIST" | grep -qxF "$DOC_ID"; then
    EXCLUDED=$((EXCLUDED + 1))
    echo -e "  ${YELLOW}SKIP${NC} $DOC_ID  ${YELLOW}(excluded)${NC}"
    continue
  fi

  if echo "$SIDEBAR_CONTENT" | grep -qF "'${DOC_ID}'"; then
    echo -e "  ${GREEN}OK${NC} $DOC_ID"
  elif echo "$SIDEBAR_CONTENT" | grep -qF "\"${DOC_ID}\""; then
    echo -e "  ${GREEN}OK${NC} $DOC_ID"
  else
    echo -e "  ${RED}MISS${NC} $DOC_ID  ${RED}(missing from sidebars.ts)${NC}"
    MISSING+=("$DOC_ID  <- $file")
  fi
done <<< "$DOC_FILES"

echo ""

if [ ${#MISSING[@]} -eq 0 ]; then
  if [ "$EXCLUDED" -gt 0 ]; then
    echo -e "${GREEN}OK All $CHECKED new doc(s) accounted for ($((CHECKED - EXCLUDED)) in sidebar, $EXCLUDED excluded)${NC}"
  else
    echo -e "${GREEN}OK All $CHECKED new doc(s) have sidebar entries${NC}"
  fi
  exit 0
fi

echo -e "${RED}FAIL ${#MISSING[@]} doc(s) missing from docs/sidebars.ts:${NC}"
for entry in "${MISSING[@]}"; do
  echo -e "${RED}    $entry${NC}"
done
echo ""
echo "To fix: add the doc ID to the appropriate section in docs/sidebars.ts"
echo "To exclude intentionally: add the doc ID to docs/.sidebar-exclusions with a reason"
exit 1
